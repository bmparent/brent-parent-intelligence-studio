{
  "name": "brent-parent-intelligence-studio",
  "private": true,
  "version": "1.1.0",
  "description": "Premium freelance intelligence-studio portfolio for Brent Parent.",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/bmparent/brent-parent-intelligence-studio.git"
  },
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc -b --pretty false",
    "build": "npm run typecheck && vite build --outDir dist && vite build --ssr src/entry-server.tsx --outDir dist-ssr --emptyOutDir false && node scripts/prerender.mjs",
    "lint": "eslint .",
    "preview": "vite preview --host 0.0.0.0",
    "verify:urls": "node scripts/verify-urls.mjs",
    "preview:cf": "npm run build && npx wrangler pages dev dist"
  },
  "dependencies": {
    "@babylonjs/core": "^9.10.1",
    "gsap": "^3.14.2",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.10",
    "wrangler": "^4.98.0"
  }
}
